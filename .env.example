NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.1-8b-instruct
TEMPERATURE=0.0
MAX_TOKENS=4096
LLM_TIMEOUT=120

# Per-agent model assignments (override default NVIDIA_MODEL)
AGENT_MODEL_BUSINESS_PROFILE=meta/llama-3.1-8b-instruct
AGENT_MODEL_MARKET_ANALYSIS=meta/llama-3.3-70b-instruct
AGENT_MODEL_COMPETITIVE_ANALYSIS=nvidia/llama-3.3-nemotron-super-49b-v1.5
AGENT_MODEL_SWOT=nvidia/llama-3.3-nemotron-super-49b-v1.5
AGENT_MODEL_MARKETING=meta/llama-3.3-70b-instruct
AGENT_MODEL_REPORT_WRITER=nvidia/llama-3.3-nemotron-super-49b-v1.5
AGENT_MODEL_MARKET_RESEARCH=deepseek-ai/deepseek-v4-flash

# Database: set DATABASE_URL for PostgreSQL (Neon), leave empty for SQLite
DATABASE_URL=

# Upstash Redis for rate limiting (leave empty to use in-memory fallback)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=
FROM_EMAIL=reports@bisystem.com
REPORT_OUTPUT_DIR=reports
JOBS_DB=jobs.db
